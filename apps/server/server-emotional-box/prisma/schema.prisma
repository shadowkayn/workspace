// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"      // 推荐目前稳定使用这个
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



// prisma/schema.prisma

// ==========================================
// 用户模块
// ==========================================
model User {
  id               String           @id @default(cuid())
  openid           String           @unique
  nickname         String?
  avatarUrl        String?
  createdAt        DateTime         @default(now())

  // 关联：一个用户有多条心情记录、收藏和焦虑历史
  moodRecords      MoodRecord[]
  favorites        UserFavorite[]
  anxietyHistories AnxietyHistory[]
}

// ==========================================
// 治愈语录表
// ==========================================
model Quote {
  id          String   @id @default(cuid())
  content     String   @db.Text
  author      String   @default("佚名")
  category    String   @default("默认")
  displayDate DateTime @unique @db.Date // 展示日期（每天一条）
  createdAt   DateTime @default(now())

  // 被收藏的关系
  favoritedBy UserFavorite[]
}

// ==========================================
// 用户收藏表 （多对多中间表）
// ==========================================
model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  quoteId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  quote     Quote    @relation(fields: [quoteId], references: [id])

  @@unique([userId, quoteId]) // 防止重复收藏
}

// ==========================================
// 情绪日记表
// ==========================================
model MoodRecord {
  id        String   @id @default(cuid())
  userId    String
  title     String?  // 日记标题
  content   String   @db.Text // 日记内容
  mood      String   // 情绪类型：happy, sad, anxious, calm, excited, angry, tired, peaceful
  moodScore Int      @default(5) // 情绪强度 1-10
  tags      String[] // 标签数组：工作、生活、学习、感情等
  weather   String?  // 天气
  location  String?  // 地点
  isPrivate Boolean  @default(false) // 是否私密
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, mood])
}

// ==========================================
// 焦虑记录历史表
// ==========================================
model AnxietyHistory {
  id        String   @id @default(cuid())
  userId    String
  score     Int      // 焦虑分值
  reason    String?  @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// ==========================================
// 背景图片
// ==========================================
model BackgroundImage {
  id        String   @id @default(cuid())
  url       String
  name      String?
  category  String   @default("default")
  isActive  Boolean  @default(true)
  order     Int      @default(0)

  @@index([category, isActive, order])
}

// ==========================================
// 图片缓存表（文件去重）
// ==========================================
model ImageCache {
  id           String   @id @default(cuid())
  fileHash     String   @unique // 文件 MD5 哈希值
  cloudinaryUrl String  // Cloudinary URL
  publicId     String   // Cloudinary public_id
  fileSize     Int      // 文件大小（字节）
  mimeType     String   // 文件类型
  width        Int?     // 图片宽度
  height       Int?     // 图片高度
  uploadCount  Int      @default(1) // 上传次数（去重统计）
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([fileHash])
}

// ==========================================
// 内容安全检测日志表
// ==========================================
model SecurityLog {
  id          String   @id @default(cuid())
  userId      String?  // 用户ID（可选）
  content     String   @db.Text // 检测内容（限制长度）
  contentType String   @default("text") // 内容类型
  result      String   // 检测结果：pass, review, risky
  label       String?  // 标签（JSON）
  score       Int?     // 分数
  suggestion  String   // 建议：pass, review, risky
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([result, createdAt])
}
