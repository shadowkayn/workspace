.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #A8C8CA 0%, #D5E5E3 100%);
  padding: 60rpx 40rpx 180rpx;
  overflow: hidden;
}

/* 头部用户信息 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid rgba(255,255,255,0.8);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  margin-bottom: 24rpx;
}

.avatar-button {
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  position: relative;
}

.avatar-button::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
}

.login-badge {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  padding: 8rpx 0;
}

.nickname {
  font-size: 48rpx;
  font-weight: 600;
  color: #2c3e50;
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.login-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 44rpx;
  margin-bottom: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.login-tip {
  font-size: 24rpx;
  color: #7f8c8d;
}

/* 功能卡片 */
.card {
  background: rgba(255,255,255,0.85);
  border-radius: 32rpx;
  padding: 0 40rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.06);
  margin-bottom: 60rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}

.menu-item-last {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.menu-text {
  font-size: 32rpx;
  color: #3a5060;
  font-weight: 500;
}

.arrow {
  font-size: 56rpx;
  color: #b0bec5;
  font-weight: 300;
}

/* 分享提示 */
.share-tip {
  margin: 0 auto;
  padding: 40rpx 36rpx;
  background: linear-gradient(135deg, rgba(168, 200, 202, 0.15) 0%, rgba(255, 255, 255, 0.8) 100%);
  border-radius: 28rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid rgba(168, 200, 202, 0.25);
  position: relative;
  overflow: hidden;
}

.share-tip::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  background: linear-gradient(180deg, #A8C8CA 0%, #8ab4b6 100%);
}

.tip-icon {
  width: 52rpx;
  height: 52rpx;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: #5d7a85;
  line-height: 1.7;
  letter-spacing: 1rpx;
  font-weight: 400;
}

.avatar-button {
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  position: relative;
}

.avatar-button::after {
  border: none;
}

.login-form {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.nickname-input {
  width: 400rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 32rpx;
  color: #2c3e50;
  background: rgba(255,255,255,0.9);
  border-radius: 40rpx;
  margin-bottom: 20rpx;
  padding: 0 30rpx;
  border: 2rpx solid rgba(102, 126, 234, 0.2);
}
