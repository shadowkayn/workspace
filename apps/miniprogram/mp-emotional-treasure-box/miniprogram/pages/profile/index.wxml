<view class="container">
  <!-- 头部用户信息 -->
  <view class="header">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo ? userInfo.avatarUrl : '/images/avatar.png'}}" mode="aspectFill"></image>
    </view>
    <text class="nickname">{{userInfo ? userInfo.nickName : '情绪观察员'}}</text>
    
    <!-- 未登录显示登录按钮 -->
    <button 
      wx:if="{{!isLogin}}"
      class="login-btn"
      bindtap="handleLogin">
      <text>一键登录</text>
    </button>
    <text class="login-tip" wx:if="{{!isLogin}}">登录后可使用收藏等功能</text>
  </view>

  <!-- 功能卡片 -->
  <view class="card">
    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-left">
        <text class="icon">⭐</text>
        <text class="menu-text">拾光宝盒 (收藏金句)</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToMoodHistory">
      <view class="menu-left">
        <text class="icon">📝</text>
        <text class="menu-text">情绪历史 (心情记录)</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToHistory">
      <view class="menu-left">
        <text class="icon">🗑️</text>
        <text class="menu-text">碎碎平安 (粉碎记录)</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 分享提示 -->
  <view class="share-tip">
    <image class="tip-icon" src="/images/icons/share.png"/>
    <text class="tip-text">点击右上角「···」分享给共鸣的人</text>
  </view>
</view>

<!-- 首次登录填写弹窗 -->
<view class="profile-dialog-mask" wx:if="{{showProfileDialog}}">
  <view class="profile-dialog" catchtap="stopPropagation">
    <view class="dialog-title">完善资料</view>
    <view class="dialog-content">
      <!-- 头像选择 -->
      <view class="form-item">
        <text class="form-label">头像</text>
        <button class="avatar-picker" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
          <image class="picker-avatar" src="{{tempAvatarUrl || '/images/avatar.png'}}" mode="aspectFill"></image>
          <text class="picker-tip">点击选择</text>
        </button>
      </view>
      
      <!-- 昵称输入 -->
      <view class="form-item">
        <text class="form-label">昵称</text>
        <input 
          class="nickname-field"
          type="nickname"
          value="{{tempNickname}}"
          placeholder="请输入昵称"
          bindinput="onNicknameInput"
          maxlength="20"
        />
      </view>
    </view>
    
    <view class="dialog-footer">
      <button class="dialog-btn cancel-btn" bindtap="handleCancelProfile">取消</button>
      <button class="dialog-btn confirm-btn" bindtap="handleSaveProfile">确定</button>
    </view>
  </view>
</view>
