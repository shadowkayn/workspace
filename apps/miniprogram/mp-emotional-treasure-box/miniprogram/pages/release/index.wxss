.container {
  height: 100%;
  background: linear-gradient(180deg, #A8C8CA 0%, #D5E5E3 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 50rpx 190rpx 50rpx;
  width: 100%;
  overflow: hidden;
}

.container-inner {
  width: 100%;
  background-color: #f1f7f7;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  border-radius: 32rpx;
  padding-bottom: 40rpx;
  overflow: hidden;
}

/* 头部区域 */
.header {
  margin-top: 50rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2c2c2c;
  letter-spacing: 4rpx;
}

.subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
  letter-spacing: 2rpx;
}

.stats {
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.stats-text {
  font-size: 22rpx;
  color: #666;
}

.stats-link {
  font-size: 22rpx;
  color: #7a96ad;
  text-decoration: underline;
}

/* 输入卡片 */
.card {
  margin: 40rpx 30rpx;
  height: 280rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

.input-area {
  width: 100%;
  height: calc(100% - 40rpx);
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  font-family: 'ZCool', serif;
}

.char-count {
  position: absolute;
  bottom: 20rpx;
  right: 30rpx;
  font-size: 22rpx;
  color: #bbb;
}

/* ========== 碎纸机区域 ========== */
.shredder-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  margin-top: 20rpx;
  height: 500rpx;
}

/* 纸张 */
.paper {
  width: 200rpx;
  height: 120rpx;
  background: #fff;
  border: 2rpx solid #c5d4e0;
  border-radius: 4rpx;
  position: relative;
  z-index: 3;
  transition: height 0.8s ease-in, opacity 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx;
}

.paper-fold {
  position: absolute;
  top: 0;
  right: 0;
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #e0eaf0 50%, #fff 50%);
  border-bottom-left-radius: 4rpx;
}

.paper-text {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}

.paper.feeding {
  height: 0rpx;
  opacity: 0;
}

/* 碎纸机机身 */
.machine {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -8rpx;
  transition: transform 0.1s ease;
}

.machine.working {
  animation: machineShake 0.1s infinite;
}

@keyframes machineShake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-2rpx); }
  75% { transform: translateX(2rpx); }
}

.machine-slot {
  width: 260rpx;
  height: 16rpx;
  background: #b8ccd8;
  border-radius: 8rpx 8rpx 0 0;
}

.machine-body {
  width: 300rpx;
  height: 100rpx;
  background: linear-gradient(180deg, #dce8ef 0%, #c5d5e0 100%);
  border: 2rpx solid #b0c4d0;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.shred-btn {
  width: 220rpx;
  height: 64rpx;
  background: linear-gradient(180deg, #8ea8c0 0%, #7a96ad 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.shred-btn:active:not(.disabled) {
  transform: scale(0.95);
}

.shred-btn text {
  font-size: 28rpx;
  color: #fff;
  letter-spacing: 4rpx;
  font-weight: 500;
}

.shred-btn.disabled {
  opacity: 0.6;
}

.machine-bottom {
  width: 280rpx;
  height: 24rpx;
  background: #c5d5e0;
  border-radius: 0 0 4rpx 4rpx;
  display: flex;
  justify-content: center;
  gap: 6rpx;
  padding: 0 16rpx;
  border-top: 2rpx solid #b0c4d0;
}

.teeth {
  width: 10rpx;
  height: 24rpx;
  background: #aec0cc;
  border-radius: 0 0 3rpx 3rpx;
}

/* ========== 碎纸条 ========== */
.strips-zone {
  position: relative;
  width: 260rpx;
  height: 140rpx;
  z-index: 1;
}

.strip {
  position: absolute;
  top: 0;
  width: 8rpx;
  height: 0;
  background: linear-gradient(180deg, #d0dde6, #e8eff4);
  border: 1rpx solid #bccdd8;
  border-radius: 0 0 2rpx 2rpx;
  opacity: 0;
}

.strips-zone.animating .strip {
  animation: stripGrow 1s ease-out forwards;
}

@keyframes stripGrow {
  0% {
    height: 0;
    opacity: 0;
  }
  20% {
    opacity: 1;
  }
  60% {
    height: 120rpx;
    opacity: 1;
  }
  100% {
    height: 120rpx;
    opacity: 0.6;
    transform: translateY(20rpx);
  }
}

/* ========== 飘落碎纸片 ========== */
.confetti-zone {
  position: absolute;
  top: 340rpx;
  width: 320rpx;
  height: 200rpx;
  z-index: 1;
}

.confetti {
  position: absolute;
  top: 0;
  width: 16rpx;
  height: 20rpx;
  border: 2rpx solid #9bb5c8;
  border-radius: 3rpx;
  background: rgba(200, 218, 230, 0.5);
  opacity: 0;
}

.confetti-zone.animating .confetti {
  animation: confettiFall 1.6s ease-in forwards;
}

@keyframes confettiFall {
  0% {
    opacity: 0;
    transform: translateY(0) rotate(0deg) scale(0.5);
  }
  15% {
    opacity: 1;
  }
  50% {
    opacity: 0.8;
  }
  100% {
    opacity: 0;
    transform: translateY(180rpx) rotate(360deg) scale(1);
  }
}

/* ========== 碎纸堆 ========== */
.pile {
  position: absolute;
  bottom: 0;
  width: 360rpx;
  height: 100rpx;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.pile.visible {
  opacity: 1;
}

.pile-piece {
  position: absolute;
  background: #dce8ef;
  border: 1rpx solid #bccdd8;
  border-radius: 3rpx;
}
