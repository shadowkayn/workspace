<view class="container">
  <!-- 背景图 -->
  <image class="bg-image" src="{{bgImage}}" mode="aspectFill"></image>

  <!-- 音乐按钮 -->
  <view class="music-btn {{musicPlaying ? 'rotating' : ''}}" bindtap="toggleMusic">
    <image src="/images/icons/music.png" mode="aspectFit"></image>
  </view>

  <!-- 语录内容区 -->
  <view class="quote-wrapper">
    <view class="quote-text">{{quote}}</view>
    <view class="quote-author">
      —— {{author}}
      <!-- 收藏按钮 -->
      <view class="favorite-btn {{isFavorited ? 'favorited' : ''}}" bindtap="toggleFavorite">
        <text class="heart-icon">{{isFavorited ? '♥' : '♡'}}</text>
      </view>
    </view>
  </view>

  <!-- 生成日签按钮 -->
  <view class="share-btn" bindtap="generateDailyCard">
    <text>生成日签分享</text>
  </view>

  <!-- 日签生成画布（隐藏） -->
  <view style="position:fixed;left:-9999px;">
    <canvas type="2d" id="dailyCardCanvas" style="width:450px;height:800px;"></canvas>
  </view>

  <!-- 日签预览弹窗 - 3D翻牌效果 -->
  <view class="card-modal" wx:if="{{showCardModal}}" bindtap="closeCardModal">
    <view class="card-flip-container {{cardFlipped ? 'flipped' : ''}}" catchtap="">
      <!-- 卡片背面 -->
      <view class="card-face card-back">
        <view class="card-back-pattern">
          <view class="pattern-circle"></view>
          <text class="pattern-text">✦ 今日清醒 ✦</text>
        </view>
      </view>
      <!-- 卡片正面 -->
      <view class="card-face card-front">
        <image class="card-preview" src="{{cardImagePath}}" mode="aspectFit"></image>
      </view>
    </view>
    <view class="card-actions" wx:if="{{cardFlipped}}">
      <button class="save-btn" catchtap="saveCardToAlbum">保存到相册</button>
    </view>
  </view>

</view>
