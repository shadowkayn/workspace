<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="title">碎碎平安</view>
    <view class="subtitle">已粉碎 {{historyList.length}} 次焦虑</view>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:elif="{{isEmpty}}">
    <view class="empty-icon">📝</view>
    <view class="empty-text">还没有粉碎记录</view>
    <view class="empty-tip">去写下你的焦虑，让它消失吧</view>
    <navigator url="/pages/release/index" open-type="switchTab" class="empty-btn">
      <text>去粉碎焦虑</text>
    </navigator>
  </view>

  <!-- 历史列表 -->
  <view class="list" wx:else>
    <view class="list-item" wx:for="{{historyList}}" wx:key="_id">
      <view class="item-content" bindtap="viewDetail" data-item="{{item}}">
        <view class="item-text">{{item.content}}</view>
        <view class="item-date">{{item.dateStr}}</view>
      </view>
      <view class="item-delete" bindtap="deleteItem" data-item="{{item}}">
        <text>删除</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="footer" wx:if="{{!isEmpty && !loading}}">
    <view class="clear-btn" bindtap="clearAll">
      <text>清空所有记录</text>
    </view>
  </view>
</view>
