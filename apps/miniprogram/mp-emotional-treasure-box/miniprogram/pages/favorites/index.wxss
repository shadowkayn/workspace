.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #A8C8CA 0%, #D5E5E3 100%);
  padding-bottom: 40rpx;
}

.header {
  padding: 60rpx 40rpx 40rpx;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #5d4e37;
  font-family: ZCool, sans-serif;
}

.count {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #95a5a6;
}

.list {
  padding: 20rpx 30rpx;
}

.item {
  background: linear-gradient(180deg, #f5f8fa 0%, #e8f1f5 100%);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.item-content {
  padding: 40rpx 32rpx;
}

.quote {
  font-size: 32rpx;
  line-height: 1.8;
  color: #2c3e50;
  font-family: ZCool, sans-serif;
  margin-bottom: 24rpx;
}

.meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.author {
  font-size: 28rpx;
  color: #7f8c8d;
}

.date {
  font-size: 24rpx;
  color: #bdc3c7;
}

.item-actions {
  display: flex;
  border-top: 1rpx solid #ecf0f1;
}

.action-btn {
  flex: 1;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  transition: background 0.2s;
}

.action-btn.share {
  color: #3498db;
  border-right: 1rpx solid #ecf0f1;
}

.action-btn.delete {
  color: #e74c3c;
}

.action-btn:active {
  background: #f8f9fa;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon {
  font-size: 160rpx;
  color: #dfe6e9;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #95a5a6;
  margin-bottom: 60rpx;
}

.empty-btn {
  padding: 24rpx 80rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
}

/* 日签预览弹窗 */
.card-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

/* 3D翻牌容器 */
.card-flip-container {
  width: 560rpx;
  height: 996rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.8s ease-in-out;
}

.card-flip-container.flipped {
  transform: rotateY(180deg);
}

/* 卡片面 */
.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.4);
}

/* 卡片背面 */
.card-back {
  background: url('https://res.cloudinary.com/kayn-admin-cloud/image/upload/v1774504376/clarity-n-bk_vwvqmq.png') no-repeat;
  background-size: 100% 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-back-pattern {
  width: 480rpx;
  height: 880rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: 
    radial-gradient(circle at 30% 30%, rgba(255, 255, 255, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 70% 70%, rgba(255, 255, 255, 0.08) 0%, transparent 50%);
}

.pattern-circle {
  width: 200rpx;
  height: 200rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 50%;
  margin-bottom: 60rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
}

.pattern-text {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 8rpx;
}

/* 卡片正面 */
.card-front {
  transform: rotateY(180deg);
  background: #d4e4e1;
}

.card-preview {
  width: 100%;
  height: 100%;
}

.card-actions {
  margin-top: 30rpx;
  margin-bottom: 60rpx;
  animation: fadeInUp 0.5s ease-out 0.3s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.save-btn {
  background: #fff;
  color: #3a5060;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 48rpx;
  font-weight: 500;
}
